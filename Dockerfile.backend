# Backend: Flask + RoBERTa chatgpt-detector
# Target: ~2.5 GB (multi-stage to keep runtime lean)
FROM python:3.11-slim-bookworm as builder

WORKDIR /build

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements (assume app uses requirements.txt)
COPY backend/requirements.txt .

# Install Python deps, using CPU torch to save ~500 MB
RUN pip install --user --no-cache-dir \
    torch --index-url https://download.pytorch.org/whl/cpu && \
    pip install --user --no-cache-dir -r requirements.txt

# Download and bake RoBERTa model + NLTK data at build time
RUN python3 << 'EOF'
import nltk
nltk.download('punkt', download_dir='/build/nltk_data')
nltk.download('punkt_tab', download_dir='/build/nltk_data')
nltk.download('stopwords', download_dir='/build/nltk_data')

from transformers import AutoTokenizer, AutoModelForSequenceClassification
model_name = "Hello-SimpleAI/chatgpt-detector-roberta"
tokenizer = AutoTokenizer.from_pretrained(model_name)
model = AutoModelForSequenceClassification.from_pretrained(model_name)
model.save_pretrained('/build/model_cache/chatgpt-detector')
tokenizer.save_pretrained('/build/model_cache/chatgpt-detector')
EOF

# Runtime stage
FROM python:3.11-slim-bookworm

WORKDIR /app

# Install runtime dependencies only
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy Python packages from builder
COPY --from=builder /root/.local /root/.local

# Copy NLTK data and model cache
COPY --from=builder /build/nltk_data /app/nltk_data
COPY --from=builder /build/model_cache /app/model_cache

# Set environment for NLTK data path and model cache
ENV PATH=/root/.local/bin:$PATH \
    NLTK_DATA=/app/nltk_data \
    TRANSFORMERS_CACHE=/app/model_cache \
    PYTHONUNBUFFERED=1

# Copy application code
COPY backend/ .

# Create non-root user for security
RUN useradd -m -u 1000 appuser && chown -R appuser:appuser /app
USER appuser

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:5000/health || exit 1

# Entrypoint: Single worker (each loads ~1.5 GB model resident)
EXPOSE 5000
CMD ["gunicorn", "--workers", "1", "--threads", "4", "--timeout", "120", "--bind", "0.0.0.0:5000", "app:app"]
